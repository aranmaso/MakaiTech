		<fadeOutTime>0.35</fadeOutTime>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<growthRate>0</growthRate>
		<speedPerTime>-5</speedPerTime>
		<rotateTowardsMoveDirectionExtraAngle>5</rotateTowardsMoveDirectionExtraAngle>
		<graphicData>
			<texPath>Things/Mote/Mote_MakaiSparkA</texPath>
			<shaderType>MoteGlow</shaderType>
			<drawSize>2</drawSize>
			<color>(95,87,165,255)</color>
			<!-- <color>(255,255,0)</color> -->
			<renderQueue>3200</renderQueue>
		</graphicData>
